{
  "name": "sgi-cdce-anzoategui-pro",
  "private": true,
  "version": "10.0.0",
  "description": "Sistema de Gestión Integral con Motor SQLite y Blindaje de Inteligencia Artificial para el CDCE Anzoátegui",
  "main": "main.js",
  "type": "module",
  "author": "Coordinación FUNDABIT Anzoátegui",
  "scripts": {
    "dev": "node server.js",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc && vite build",
    "start": "node server.js",
    "electron:dev": "npm run fix:electron && electron .",
    "dist": "npm run build && npm run fix:electron && npx electron-builder",
    "fix:electron": "npx electron-builder install-app-deps",
    "share": "npx cloudflared tunnel --protocol http2 --url http://127.0.0.1:3001"
  },
  "build": {
    "appId": "com.sgi.anzoategui.pro",
    "productName": "SGI Anzoategui Pro",
    "directories": {
      "output": "dist_exe"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "venezuela.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "SGI ANZOATEGUI",
      "createDesktopShortcut": true,
      "installerIcon": "venezuela.ico",
      "uninstallerIcon": "venezuela.ico"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "server.js",
      "node_modules/**/*",
      "package.json",
      "venezuela.png",
      "venezuela.ico"
    ],
    "extraResources": [
      {
        "from": "sgi_enterprise.db",
        "to": "sgi_enterprise.db",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "better-sqlite3": "^12.6.2",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
